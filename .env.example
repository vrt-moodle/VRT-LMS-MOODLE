# Copy this file to .env for local overrides.
# Do not commit real secrets.

APP_ENV=test
APP_NAME=VRT-LMS-MOODLE
APP_URL=http://localhost:5090

MOODLE_DB_TYPE=pgsql
MOODLE_DB_HOST=YOUR_DB_HOST
MOODLE_DB_PORT=5432
MOODLE_DB_NAME=YOUR_DB_NAME
MOODLE_DB_USER=YOUR_DB_USER
MOODLE_DB_PASSWORD=YOUR_DB_PASSWORD

MOODLE_WWWROOT=http://YOUR_DOMAIN_OR_IP:5090
MOODLE_DATAROOT=/var/www/moodledata
MOODLE_ADMIN_PATH=admin
